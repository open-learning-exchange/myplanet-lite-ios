"privacy_title" = "गोपनीयता नीति";
"privacy_intro_title" = "परिचय";
"privacy_intro_body" = "यो गोपनीयता नीतिले तपाईंले सेवा प्रयोग गर्दा तपाईंको जानकारीको सङ्कलन, प्रयोग र खुलासामा हाम्रा नीति र प्रक्रियाहरू वर्णन गर्दछ र तपाईंलाई तपाईंको गोपनीयता अधिकार र कानूनले तपाईंलाई कसरी संरक्षण गर्छ भन्ने बारे बताउँछ।\n\nहामी सेवा प्रदान गर्न र सुधार गर्न तपाईंको व्यक्तिगत डेटा प्रयोग गर्दछौं। सेवा प्रयोग गरेर, तपाईं यस गोपनीयता नीति अनुसार जानकारीको सङ्कलन र प्रयोगमा सहमत हुनुहुन्छ।\n\nअन्तिम अद्यावधिक: अप्रिल १०, २०२०";
"privacy_definitions_title" = "व्याख्या र परिभाषाहरू";
"privacy_definitions_body" = "जुन शब्दहरूको पहिलो अक्षर ठूलो छ, तिनीहरूको अर्थ निम्न परिस्थितिहरूमा परिभाषित गरिएको छ। निम्न परिभाषाहरूको अर्थ एउटै हुनेछ चाहे तिनीहरू एकवचन वा बहुवचनमा देखा परोस्।\n\n• कम्पनी भन्नाले ओपन लर्निङ एक्सचेन्ज, वान ब्रोडवे, क्याम्ब्रिज, एमए, संयुक्त राज्य अमेरिकालाई बुझाउँछ।\n• एप्लिकेसन भन्नाले कम्पनीद्वारा उपलब्ध गराइएको सफ्टवेयर प्रोग्राम बुझाउँछ जुन तपाईंले कुनै पनि इलेक्ट्रोनिक उपकरणमा डाउनलोड गर्नुभएको छ, जसको नाम myPlanet हो।\n• व्यक्तिगत डेटा भन्नाले पहिचान गरिएको वा पहिचान गर्न सकिने व्यक्तिसँग सम्बन्धित कुनै पनि जानकारी हो।\n• प्रयोग डेटा भन्नाले सेवाको प्रयोगबाट वा सेवा पूर्वाधारबाट स्वतः उत्पन्न हुने डेटालाई बुझाउँछ।";
"privacy_collect_title" = "तपाईंको व्यक्तिगत डेटा सङ्कलन र प्रयोग";
"privacy_collect_body" = "हाम्रो सेवा प्रयोग गर्दा, हामी तपाईंलाई केही व्यक्तिगत रूपमा पहिचान योग्य जानकारी प्रदान गर्न सोध्न सक्छौं जुन तपाईंलाई सम्पर्क गर्न वा पहिचान गर्न प्रयोग गर्न सकिन्छ। व्यक्तिगत रूपमा पहिचान योग्य जानकारीमा निम्न कुराहरू समावेश हुन सक्छन्, तर यी मात्र होइनन्: इमेल ठेगाना, फोन नम्बर, ठेगाना, राज्य, प्रान्त, जिप/पोस्टल कोड, शहर, र प्रयोग डेटा।\n\nसेवा प्रयोग गर्दा प्रयोग डेटा स्वतः सङ्कलन गरिन्छ। यसमा तपाईंको उपकरणको इन्टरनेट प्रोटोकल ठेगाना (जस्तै IP ठेगाना), ब्राउजर प्रकार, ब्राउजर संस्करण, तपाईंले भ्रमण गर्नुभएको हाम्रो सेवाका पृष्ठहरू, र अन्य निदान डेटा जस्ता जानकारी समावेश हुन सक्छ।\n\nहाम्रो एप्लिकेसन प्रयोग गर्दा, हामी तपाईंको पूर्व अनुमतिमा सङ्कलन गर्न सक्छौं: तपाईंको स्थान सम्बन्धी जानकारी, तपाईंको उपकरणको क्यामेरा र फोटो लाइब्रेरीबाट चित्रहरू र अन्य जानकारी।";
"privacy_use_title" = "तपाईंको व्यक्तिगत डेटाको प्रयोग";
"privacy_use_body" = "कम्पनीले व्यक्तिगत डेटा हाम्रो सेवा प्रदान गर्न र कायम राख्न, तपाईंको खाता व्यवस्थापन गर्न, सम्झौताको कार्यसम्पादनका लागि, तपाईंलाई सम्पर्क गर्न, तपाईंलाई समाचार र विशेष प्रस्तावहरू प्रदान गर्न, र तपाईंको अनुरोधहरू व्यवस्थापन गर्न प्रयोग गर्न सक्छ।\n\nहामी तपाईंको व्यक्तिगत जानकारी सेवा प्रदायकहरू, व्यवसाय स्थानान्तरणका लागि, सम्बद्ध कम्पनीहरू, व्यापार साझेदारहरू र अन्य प्रयोगकर्ताहरूसँग साझा गर्न सक्छौं।";
"privacy_retention_title" = "तपाईंको व्यक्तिगत डेटाको प्रतिधारण";
"privacy_retention_body" = "कम्पनीले यस गोपनीयता नीतिमा तोकिएका उद्देश्यका लागि आवश्यक भएसम्म मात्र तपाईंको व्यक्तिगत डेटा राख्नेछ। हामी हाम्रा कानुनी दायित्वहरू पालना गर्न, विवादहरू समाधान गर्न र हाम्रा कानुनी सम्झौता र नीतिहरू लागू गर्न आवश्यक हदसम्म तपाईंको व्यक्तिगत डेटा राख्नेछौं र प्रयोग गर्नेछौं।";
"privacy_transfer_title" = "तपाईंको व्यक्तिगत डेटाको स्थानान्तरण";
"privacy_transfer_body" = "व्यक्तिगत डेटा सहित तपाईंको जानकारी कम्पनीको सञ्चालन कार्यालयहरू र प्रशोधनमा संलग्न पक्षहरू अवस्थित अन्य कुनै पनि ठाउँमा प्रशोधन गरिन्छ। यसको अर्थ यो जानकारी तपाईंको राज्य, प्रान्त, देश वा अन्य सरकारी क्षेत्राधिकार बाहिर रहेका कम्प्युटरहरूमा स्थानान्तरण र कायम राख्न सकिन्छ जहाँ डेटा सुरक्षा कानून तपाईंको क्षेत्राधिकार भन्दा फरक हुन सक्छ।";
"privacy_disclosure_title" = "तपाईंको व्यक्तिगत डेटाको खुलासा";
"privacy_disclosure_body" = "यदि कम्पनी मर्जर, अधिग्रहण वा सम्पत्ति बिक्रीमा संलग्न छ भने, तपाईंको व्यक्तिगत डेटा स्थानान्तरण हुन सक्छ। केही परिस्थितिहरूमा, कम्पनीले कानूनद्वारा आवश्यक भएमा वा सार्वजनिक अधिकारीहरूको वैध अनुरोधहरूको जवाफमा तपाईंको व्यक्तिगत डेटा खुलासा गर्नुपर्ने हुन सक्छ।\n\nकम्पनीले सद्भावपूर्वक विश्वासमा तपाईंको व्यक्तिगत डेटा खुलासा गर्न सक्छ कि यस्तो कार्य आवश्यक छ: कानुनी दायित्व पालना गर्न, कम्पनीको अधिकार वा सम्पत्तिको रक्षा गर्न, सम्भावित गल्तीहरू रोक्न वा अनुसन्धान गर्न, प्रयोगकर्ताहरूको व्यक्तिगत सुरक्षाको रक्षा गर्न, वा कानुनी दायित्व विरुद्ध रक्षा गर्न।";
"privacy_security_title" = "तपाईंको व्यक्तिगत डेटाको सुरक्षा";
"privacy_security_body" = "तपाईंको व्यक्तिगत डेटाको सुरक्षा हाम्रा लागि महत्त्वपूर्ण छ, तर याद गर्नुहोस् कि इन्टरनेटमा प्रसारणको कुनै पनि विधि, वा इलेक्ट्रोनिक भण्डारणको विधि १००% सुरक्षित हुँदैन। यद्यपि हामी तपाईंको व्यक्तिगत डेटा सुरक्षित गर्न व्यावसायिक रूपमा स्वीकार्य माध्यमहरू प्रयोग गर्ने प्रयास गर्छौं, हामी यसको पूर्ण सुरक्षाको ग्यारेन्टी दिन सक्दैनौं।";
"privacy_children_title" = "बालबालिकाको गोपनीयता";
"privacy_children_body" = "हाम्रो सेवाले १३ वर्ष मुनिका कसैलाई पनि सम्बोधन गर्दैन। हामीले १३ वर्ष मुनिका कसैबाट पनि व्यक्तिगत रूपमा पहिचान योग्य जानकारी जानाजानी सङ्कलन गर्दैनौं। यदि हामीलाई थाहा भयो कि हामीले आमाबाबुको सहमतिको प्रमाणीकरण बिना १३ वर्ष मुनिका कसैबाट व्यक्तिगत डेटा सङ्कलन गरेका छौं भने, हामी त्यो जानकारी हाम्रा सर्भरहरूबाट हटाउन कदम चाल्छौं।";
"privacy_links_title" = "अन्य वेबसाइटहरूको लिङ्क";
"privacy_links_body" = "हाम्रो सेवामा अन्य वेबसाइटहरूको लिङ्क हुन सक्छ जुन हामीद्वारा सञ्चालित छैनन्। यदि तपाईंले तेस्रो पक्षको लिङ्कमा क्लिक गर्नुभयो भने, तपाईंलाई त्यो तेस्रो पक्षको साइटमा निर्देशित गरिनेछ। हामी तपाईंलाई भ्रमण गर्ने प्रत्येक साइटको गोपनीयता नीति समीक्षा गर्न दृढ सल्लाह दिन्छौं।";
"privacy_updates_title" = "यस गोपनीयता नीतिमा परिवर्तनहरू";
"privacy_updates_body" = "हामी समय-समयमा हाम्रो गोपनीयता नीति अद्यावधिक गर्न सक्छौं। हामी यस पृष्ठमा नयाँ गोपनीयता नीति पोस्ट गरेर तपाईंलाई कुनै पनि परिवर्तनको बारेमा सूचित गर्नेछौं। तपाईंलाई कुनै पनि परिवर्तनको लागि समय-समयमा यो गोपनीयता नीति समीक्षा गर्न सल्लाह दिइन्छ।";
"privacy_contact_title" = "हामीलाई सम्पर्क गर्नुहोस";
"privacy_contact_body" = "यदि तपाईंलाई यस गोपनीयता नीतिको बारेमा कुनै प्रश्नहरू छन् भने, तपाईंले हामीलाई इमेल मार्फत सम्पर्क गर्न सक्नुहुन्छ: solutions@ole.org";
