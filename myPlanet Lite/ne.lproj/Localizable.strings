"privacy_intro_title" = "परिचय";
"privacy_intro_body" = "यो गोपनीयता नीतिले तपाईंको संस्थामार्फत उपलब्ध MyPlanet Lite ले एप प्रयोग गर्दा व्यक्तिगत डाटा कसरी व्यवस्थापन गर्छ भन्ने स्पष्ट गर्छ।";
"privacy_collect_title" = "हामीले संकलन गर्ने जानकारी";
"privacy_collect_body" = "हामी संकलन गर्छौं:\n• खाता डाटा (नाम, प्रयोगकर्ता नाम, इमेल, संस्था)।\n• प्रयोग र निदान जानकारी (सेसन गतिविधि, सुविधासँगको अन्तरक्रिया, उपकरण र एप संस्करण)।\n• तपाईंले पठाउने वैकल्पिक सामग्री (पोस्ट, सर्वे जवाफ, मिडिया फाइलहरू)।";
"privacy_use_title" = "हामी तपाईंको जानकारी कसरी प्रयोग गर्छौं";
"privacy_use_body" = "हामी डाटालाई मुख्य सुविधा प्रदान गर्न, सिकाइ सामग्री समक्रमण गर्न, भाषा र क्षेत्रीय सेटिङ् अनुकूलित गर्न, कार्यसम्पादन र विश्वसनीयता सुधार गर्न, तथा सुरक्षा, धोखाधडी रोकथाम र अनुसन्धानमा सहयोग गर्न प्रयोग गर्छौं।";
"privacy_storage_title" = "भण्डारण र अवधारण";
"privacy_storage_body" = "जानकारी OLE वा तपाईंको संस्थाले व्यवस्थापन गर्ने सुरक्षित सर्भरहरूमा पहुँच नियन्त्रण र ट्रान्जिटमा इन्क्रिप्सनसहित राखिन्छ। हामी सेवा दिन आवश्यक समयसम्म, कानुनी आवश्यकताहरू पूरा गर्न, सम्झौता लागू गर्न वा विवाद समाधान गर्न मात्र डाटा राख्छौं, ब्याकअपका लागि सीमित अवधारणसहित।";
"privacy_share_title" = "साझेदारी र तेस्रो पक्ष";
"privacy_share_body" = "हामी व्यक्तिगत डाटा बेच्दैनौं। जानकारी विश्वसनीय सेवा प्रदायकहरू (जस्तै होस्टिङ, एनालिटिक्स वा सूचनाहरू) सँग डाटा संरक्षण सम्झौताअनुसार, तपाईंको संस्थाका प्रशासकहरूसँग खाता व्यवस्थापनका लागि, वा कानुनले मागेमा साझा हुन सक्छ।";
"privacy_rights_title" = "तपाईंका विकल्प र अधिकार";
"privacy_rights_body" = "तपाईं एपभित्र आफ्नो प्रोफाइल डाटा समीक्षा वा अपडेट गर्न सक्नुहुन्छ। आवश्यक परेमा, तपाईं आफ्नो डाटामा पहुँच, सुधार, मेटाउने, प्रतिबन्ध वा पोर्टेबिलिटी अनुरोध गर्न सक्नुहुन्छ, वा केही प्रशोधनको विरोध गर्न सक्नुहुन्छ। तपाईं वैकल्पिक डाटालाई त्यो सामग्री मेटाएर वा पठाउन रोकिएर फिर्ता लिन सक्नुहुन्छ।";
"privacy_security_title" = "सुरक्षा";
"privacy_security_body" = "हामी ट्रान्जिट इन्क्रिप्सन (TLS), प्रमाणीकरण नियन्त्रण, न्यूनतम विशेषाधिकार पहुँच र निगरानीजस्ता प्राविधिक तथा संगठनात्मक उपाय लागू गर्छौं ताकि अनधिकृत पहुँच वा खुलासाको जोखिम घटोस्। आफ्ना क्रेडेन्सियल सुरक्षित राख्नुहोस्।";
"privacy_children_title" = "बालबालिकाको डाटा";
"privacy_children_body" = "यो एप साझेदार संस्थामार्फत अनुमति प्राप्त शिक्षार्थीहरूको लागि हो। आवश्यक सहमति बिना कुनै बालबालिकाको डाटा संकलन भएको छ भने हटाउनका लागि हामीलाई सम्पर्क गर्नुहोस्।";
"privacy_updates_title" = "नीति अपडेटहरू";
"privacy_updates_body" = "हामी उत्पादन, सुरक्षा वा कानुनी आवश्यकतामा परिवर्तनहरू प्रतिबिम्बित गर्न यो नीति अपडेट गर्न सक्छौं। महत्वपूर्ण अपडेटहरू एपभित्रको सूचना वा अन्य उपयुक्त माध्यममार्फत जानकारी गराइनेछ।";
"privacy_contact_title" = "सम्पर्क";
"privacy_contact_body" = "प्रश्नहरू वा गोपनीयता अधिकार प्रयोग गर्नका लागि, तपाईंको संस्थाको प्रशासक वा हाम्रो सहयोग टोलीलाई सम्पर्क गर्नुहोस्।";
