"eula_title" = "अन्तिम प्रयोगकर्ता लाइसेन्स सम्झौता (EULA)";
"eula_subtitle" = "Open Learning Exchange";
"eula_section1_title" = "1. सम्झौताको स्वीकृति";
"eula_section1_body" = "यस Android एपमा \"स्वीकार गर्नुहोस्\" चयन गर्दा, तपाईंले यो अन्तिम प्रयोगकर्ता लाइसेन्स सम्झौता (\"सम्झौता\") पढ्नुभएको, बुझ्नुभएको र स्वीकार गर्नुभएको पुष्टि गर्नुहुन्छ।";
"eula_section2_title" = "2. स्वामित्व";
"eula_section2_body" = "Open Learning Exchange (\"OLE\") Planet, myPlanet र myPlanetLite एपहरूका साथै तिनको सामग्री, डिजाइन, कोड र सम्बन्धित सामग्रीहरूको मालिक हो।";
"eula_section3_title" = "3. प्रयोगको लाइसेन्स";
"eula_section3_body" = "OLE ले प्रयोगकर्तालाई सीमित, व्यक्तिगत, गैर-अनन्य र हस्तान्तरण गर्न नमिल्ने लाइसेन्स प्रदान गर्छ जसले यस Android एपलाई उनीहरूको संस्था वा संगठनले अनुमति दिएका उद्देश्यहरूका लागि मात्र स्थापना र प्रयोग गर्न अनुमति दिन्छ।";
"eula_section4_title" = "4. डाटा, सुरक्षा र गोपनीयता";
"eula_section4_body" = "4.1. एपहरूले प्रमाणीकरण, सञ्चालन र प्रयोगकर्ता समक्रमणका लागि आवश्यक व्यक्तिगत डाटा संकलन र प्रशोधन गर्नुपर्छ।\n4.2. एपहरूले पठाएको वा भण्डारण गरेको सबै डाटा लागू सुरक्षा मापदण्डअनुसार एन्क्रिप्ट गरिएको हुन्छ।\n4.3. प्रयोगकर्ताले एपहरूको प्रयोगले यस्तो सुरक्षित प्रशोधन समेट्छ भन्ने कुरा स्वीकार गर्छ।";
"eula_section5_title" = "5. प्रणालीबाट हट्ने";
"eula_section5_body" = "यदि प्रयोगकर्ताले आफ्नो खाता निष्क्रिय वा हटाउन चाहन्छ भने, Planet प्लेटफर्मभित्रका प्रशासकसँग प्रत्यक्ष सम्पर्क गर्नुपर्छ, जसले निर्धारित प्रक्रियाअनुसार पहुँच बन्द वा डाटा हटाउने काम व्यवस्थापन गर्नेछ।";
"eula_section6_title" = "6. प्रयोगकर्ताको दायित्व";
"eula_section6_body" = "प्रयोगकर्ता सहमत हुन्छ कि:\n• लागू नियमहरूको पालना गर्दै जिम्मेवारीपूर्वक एप प्रयोग गर्ने।\n• तोकिएको लगइन जानकारी सुरक्षित राख्ने।\n• कुनै दुरुपयोग वा शंकास्पद गतिविधि भएमा आफ्नो संस्थागत प्रशासकलाई रिपोर्ट गर्ने।";
"eula_section7_title" = "7. सम्झौतामा परिवर्तन";
"eula_section7_body" = "OLE ले आवश्यक परेमा यी सर्तहरू अद्यावधिक गर्न सक्छ। कुनै पनि परिवर्तनपछि एपको निरन्तर प्रयोगले अद्यावधिक सम्झौता स्वीकार गरेको मानिन्छ।";
"eula_section8_title" = "8. पुष्टि";
"eula_section8_body" = "\"स्वीकार गर्नुहोस्\" ट्याप गर्दा, तपाईंले:\n• यो सम्झौता पढ्नुभएको छ।\n• यसको दायरा बुझ्नुभएको छ।\n• यसको नियम र सर्तहरू पूर्ण रूपमा स्वीकार गर्नुभएको छ।";
