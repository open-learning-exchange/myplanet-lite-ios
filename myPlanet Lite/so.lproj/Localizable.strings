"menu_privacy" = "Siyaasadda asturnaanta";
"privacy_title" = "Siyaasadda asturnaanta";
"privacy_intro_title" = "Hordhac";
"privacy_intro_body" = "Siyaasaddan Asturnaanta waxay qeexaysaa siyaasadahayaga iyo habraacyadayada ku saabsan ururinta, isticmaalka iyo soo bandhigida macluumaadkaaga marka aad isticmaasho Adeegga waxayna kuu sheegaysaa xuquuqdaada asturnaanta iyo sida sharcigu kuu ilaalinayo.\n\nWaxaan u isticmaalnaa xogtaada shakhsi ahaaneed si aan u bixinno una horumarino Adeegga. Markaad isticmaasho Adeegga, waxaad ogolaatay ururinta iyo isticmaalka macluumaadka si waafaqsan Siyaasaddan Asturnaanta.\n\nCusboonaysiintii ugu dambaysay: Abriil 10, 2020";
"privacy_definitions_title" = "Fasiraadda iyo Qeexidda";
"privacy_definitions_body" = "Erayada xarafka hore uu yahay far waaweyn waxay leeyihiin macneyaal lagu qeexay shuruudahan soo socda. Qeexitaannada soo socda waxay yeelan doonaan macne isku mid ah iyadoon loo eegin inay u muuqdaan kali ama wadajir.\n\n• Shirkadda waxaa loola jeedaa Open Learning Exchange, One Broadway, Broadway, Cambridge, MA, Mareykanka.\n• Codsiga waxaa loola jeedaa barnaamijka softiweerka ah ee ay bixiso Shirkadda ee aad ku soo dejisatay qalab kasta oo elektaroonig ah, oo loogu magac daray myPlanet.\n• Xogta Shakhsi ahaaneed waa macluumaad kasta oo la xidhiidha qof la aqoonsaday ama la aqoonsan karo.\n• Xogta Isticmaalka waxaa loola jeedaa xogta si toos ah loo ururiyo, ama laga soo saaro isticmaalka Adeegga ama kaabayaasha Adeegga laftiisa.";
"privacy_collect_title" = "Ururinta iyo Isticmaalka Xogtaada Shakhsi ahaaneed";
"privacy_collect_body" = "Inta aad isticmaalayso Adeeggayaga, waxaa laga yaabaa inaan ku weydiisano inaad na siiso macluumaad gaar ah oo lagu aqoonsan karo oo loo isticmaali karo in lagula soo xidhiidho ama lagugu aqoonsado. Macluumaadka shakhsi ahaaneed waxaa ka mid noqon kara, laakiin aan ku xaddidnayn: Ciwaanka iimaylka, lambarka taleefanka, Ciwaanka, Gobolka, Gobolka, Lambarka Boostada, Magaalada, iyo Xogta Isticmaalka.\n\nXogta Isticmaalka waxaa si toos ah loo ururiyaa marka la isticmaalayo Adeegga. Waxaa ku jiri kara macluumaad ay ka mid yihiin ciwaanka Protocol-ka Internetka ee qalabkaaga (tusaale ciwaanka IP), nooca browserka, nooca browserka, boggaga Adeeggayaga ee aad booqato, iyo xogta kale ee ogaanshaha.\n\nInta aad isticmaalayso Codsigayaga, waxaan u ururin karnaa, ogolaanshahaaga hore: Macluumaadka ku saabsan goobtaada, Sawirrada iyo macluumaadka kale ee kamaradda qalabkaaga iyo maktabadda sawirka.";
"privacy_use_title" = "Isticmaalka Xogtaada Shakhsi ahaaneed";
"privacy_use_body" = "Shirkaddu waxay u isticmaali kartaa Xogta Shakhsi ahaaneed si ay u bixiso uuna u ilaaliso Adeeggayaga, si ay u maamusho Koontadaada, fulinta qandaraaska, si ay kula soo xidhiidho, si ay kuu siiso warar iyo dalabyo gaar ah, iyo si ay u maamusho codsiyadaada.\n\nWaxaan la wadaagi karnaa macluumaadkaaga shakhsi ahaaneed bixiyeyaasha adeegga, wareejinta ganacsiga, lala yeesho xubnaha gacansaarka la leh, lala yeesho la-hawlgalayaasha ganacsiga, iyo isticmaaleyaasha kale.";
"privacy_retention_title" = "Haynta Xogtaada Shakhsi ahaaneed";
"privacy_retention_body" = "Shirkaddu waxay hayn doontaa Xogtaada Shakhsi ahaaneed inta ay lagama maarmaanka u tahay ujeedooyinka lagu qeexay Siyaasaddan Asturnaanta. Waxaan hayn doonaa oo u isticmaali doonaa Xogtaada Shakhsi ahaaneed inta ay lagama maarmaanka u tahay si aan u u hoggaansanno waajibaadkayaga sharciga ah, xallinta khilaafaadka, iyo dhaqangelinta heshiisyadayada iyo siyaasadaha sharciga ah.";
"privacy_transfer_title" = "Wareejinta Xogtaada Shakhsi ahaaneed";
"privacy_transfer_body" = "Macluumaadkaaga, oo ay ku jirto Xogta Shakhsi ahaaneed, waxaa lagu farsameeyaa xafiisyada hawlgalka ee Shirkadda iyo meel kasta oo kale oo ay ku yaalaan dhinacyada ku lugta leh farsamaynta. Waxay la macno tahay in macluumaadkan loo wareejin karo — lagana hayn karo — kombuyuutarrada ku yaal meel ka baxsan gobolkaaga, gobolkaaga, dalkaaga ama awoodda kale ee dawladda halkaas oo sharciyada ilaalinta xogta ay kaga duwanaan karaan kuwa awooddaada.";
"privacy_disclosure_title" = "Soo Bandhigida Xogtaada Shakhsi ahaaneed";
"privacy_disclosure_body" = "Haddii Shirkaddu ay ku lug leedahay midoobid, iibsasho ama iibinta hantida, Xogtaada Shakhsi ahaaneed waa la wareejin karaa. Xaalado gaar ah, Shirkadda waxaa laga yaabaa in looga baahdo inay shaaciso Xogtaada Shakhsi ahaaneed haddii sharcigu u baahdo ama laga jawaabayo codsiyada saxda ah ee masuuliyiinta dadwaynaha.\n\nShirkaddu waxay shaacin kartaa Xogtaada Shakhsi ahaaneed iyadoo aaminsan niyad wanaag in ficilkaas uu lagama maarmaan u yahay: u hoggaansanaanta waajibaadka sharciga ah, ilaalinta iyo difaacida xuquuqda ama hantida Shirkadda, ka hortagga ama baadhista khaladaadka suurtagalka ah, ilaalinta badbaadada shakhsi ahaaneed ee isticmaalayaasha, ama ka ilaalinta mas'uuliyadda sharciga ah.";
"privacy_security_title" = "Amniga Xogtaada Shakhsi ahaaneed";
"privacy_security_body" = "Amniga Xogtaada Shakhsi ahaaneed waa noo muhiim, laakiin xasuuso in habka gudbinta internetka, ama habka kaydinta elektaroonigga ah aysan 100% ammaan ahayn. In kasta oo aan ku dadaalayno inaan isticmaalno habab ganacsi ahaan la aqbali karo si aan u ilaalinno Xogtaada Shakhsi ahaaneed, ma dammaanad qaadi karno ammaankeeda buuxa.";
"privacy_children_title" = "Asturnaanta Carruurta";
"privacy_children_body" = "Adeeggayagu ma khuseeyo qof kasta oo ka yar 13 sano. Si badheedh ah uma ururinno macluumaadka shakhsi ahaaneed ee qof kasta oo ka yar 13 sano. Haddii aan ogaanno inaan ka soo ururinay Xogta Shakhsi ahaaneed qof kasta oo ka yar 13 sano iyada oo aan la xaqiijin oggolaanshaha waalidka, waxaan qaadeynaa tillaabooyin aan macluumaadkaas uga saarno adeegayaashayada.";
"privacy_links_title" = "Xiriirinta Mareegaha Kale";
"privacy_links_body" = "Adeeggayagu waxa uu ka koobnaan karaa xiriirinta mareegaha kale ee aanaan annagu ku shaqayn. Haddii aad gujiso xiriirka dhinac saddexaad, waxaa laguu hagi doonaa goobta dhinac saddexaad. Waxaan si adag kuugula talineynaa inaad dib u eegto Siyaasadda Asturnaanta ee goob kasta oo aad booqato.";
"privacy_updates_title" = "Isbeddelka Siyaasaddan Asturnaanta";
"privacy_updates_body" = "Waxaan cusbooneysiin karnaa siyaasaddayada asturnaanta waqti ka waqti. Waxaan kugu ogeysiin doonaa isbeddel kasta annaga oo ku dhejinayna Siyaasadda Asturnaanta cusub boggan. Waxaa lagugula talinayaa inaad dib u eegto Siyaasaddan Asturnaanta xilliyo isbeddel kasta leh.";
"privacy_contact_title" = "Nala soo xiriir";
"privacy_contact_body" = "Haddii aad qabto wax su'aalo ah oo ku saabsan Siyaasaddan Asturnaanta, waxaad nagala soo xidhiidhi kartaa iimaylka: solutions@ole.org";
