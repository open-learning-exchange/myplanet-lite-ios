"eula_title" = "Heshiiska Shatiga Isticmaalaha Ugu Dambeeya (EULA)";
"eula_subtitle" = "Open Learning Exchange";
"eula_section1_title" = "1. Oggolaanshaha Heshiiska";
"eula_section1_body" = "Adigoo dooranaya \"Oggolow\" gudaha app-kan Android, waxaad xaqiijinaysaa inaad akhriday, fahantay, oo aad oggolaatay shuruudaha ku xusan Heshiiskan Shatiga Isticmaalaha Ugu Dambeeya (\"Heshiiska\").";
"eula_section2_title" = "2. Lahaansho";
"eula_section2_body" = "Open Learning Exchange (\"OLE\") waa milkiilaha app-yada Planet, myPlanet iyo myPlanetLite, oo ay ku jiraan nuxurkooda, naqshaddooda, koodkooda, iyo agab la xiriira.";
"eula_section3_title" = "3. Shatiga Isticmaalka";
"eula_section3_body" = "OLE waxay siinaysaa isticmaaleha shati xaddidan, shakhsi ah, aan gaar ahayn, aan la wareejin karin si uu u rakibo oo u isticmaalo app-kan Android oo keliya ujeeddooyinka ay oggol yihiin hay'addiisa ama ururkiisa.";
"eula_section4_title" = "4. Xog, Amni iyo Asturnaan";
"eula_section4_body" = "4.1. App-yadu waxay u baahan yihiin ururinta iyo habaynta xog shakhsiyeed oo lagama maarmaan u ah xaqiijinta, shaqada, iyo isku xidhka isticmaaleha.\n4.2. Dhammaan xogta la gudbiyo ama la kaydiyo ee app-yadu waa la sirgeliyaa, iyadoo la raacayo heerarka amniga ee khuseeya.\n4.3. Isticmaaluhu wuxuu aqbalayaa in isticmaalka app-yadu uu ku jiro habayntan amniga leh.";
"eula_section5_title" = "5. Ka bixitaanka Nidaamka";
"eula_section5_body" = "Haddii isticmaalehu go'aansado inuu joojiyo ama tirtiro koontadiisa, waa inuu si toos ah ula xiriiro maamule ku jira madasha Planet, kaas oo maamuli doona xiritaanka gelitaanka ama tirtirka xogta iyadoo la raacayo habraacyada la dejiyey.";
"eula_section6_title" = "6. Waajibaadka Isticmaalaha";
"eula_section6_body" = "Isticmaaluhu wuxuu ballanqaadayaa inuu:\n• U isticmaalo app-ka si masuuliyad leh oo waafaqsan xeerarka khuseeya.\n• Ilaaliyo xogta gelitaanka ee loo qoondeeyey.\n• Soo sheego isticmaal khaldan ama dhaqan shaki leh maamulaha hay'addiisa.";
"eula_section7_title" = "7. Isbeddelada Heshiiska";
"eula_section7_body" = "OLE waxay cusboonaysiin kartaa shuruudahan marka loo baahdo. Sii wadidda isticmaalka app-ka ka dib wax isbeddel ah waxay ka dhigan tahay aqbalidda nooca la cusboonaysiiyay ee Heshiiska.";
"eula_section8_title" = "8. Xaqiijin";
"eula_section8_body" = "Adigoo taabanaya \"Oggolow\", waxaad qiraysaa in:\n• Aad akhriday Heshiiskan.\n• Aad fahantay baaxaddiisa.\n• Aad si buuxda u aqbashay shuruudihiisa iyo xeerarkiisa.";
