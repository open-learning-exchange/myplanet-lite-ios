"menu_privacy" = "Siyaasadda asturnaanta";
"privacy_title" = "Siyaasadda asturnaanta";
"privacy_intro_title" = "Hordhac";
"privacy_intro_body" = "Siyaasaddan asturnaanta waxay sharxaysaa sida MyPlanet Lite, oo loo bixiyo iyada oo loo marayo ururkaaga, ay u maamusho xogta shakhsiyeed marka aad isticmaasho app-ka.";
"privacy_collect_title" = "Macluumaadka aan ururinno";
"privacy_collect_body" = "Waxaan ururinnaa:\n• Xogta akoonka (magac, magac isticmaale, iimayl, urur).\n• Macluumaadka isticmaalka iyo ogaanshaha (dhaqdhaqaaqa fadhiga, isdhexgalka sifooyinka, nooca qalabka iyo app-ka).\n• Mawduuc ikhtiyaari ah oo aad dirto (qoraallo, jawaabaha sahannada, faylasha warbaahinta).";
"privacy_use_title" = "Sida aan u isticmaalno macluumaadkaaga";
"privacy_use_body" = "Waxaan u isticmaalnaa xogta si aan u bixino sifooyinka aasaasiga ah, u waafajino nuxurka waxbarashada, u shakhsiyeeyno luqadda iyo dejinta gobolka, u wanaajino waxqabadka iyo kalsoonida, iyo in aan taageerno amniga, ka hortagga khiyaanada, iyo baaritaannada.";
"privacy_storage_title" = "Kaydinta iyo haynta";
"privacy_storage_body" = "Macluumaadka waxaa lagu kaydiyaa serverro ammaan ah oo ay maamulaan OLE ama ururkaaga iyadoo leh xakamaynta gelitaanka iyo sirgalinta inta lagu jiro gudbinta. Waxaan haynaa xogta oo keliya inta ay lagama maarmaan u tahay bixinta adeegga, buuxinta shuruudaha sharciga, fulinta heshiisyada, ama xallinta murannada, iyadoo kayd xaddidan loogu hayo nuqulasha kaydka.";
"privacy_share_title" = "Wadaagista iyo dhinacyada saddexaad";
"privacy_share_body" = "Ma iibinno xog shakhsiyeed. Macluumaadka waxaa lala wadaagi karaa bixiyeyaasha adeegyada la aamini karo (tusaale, martigelinta, falanqaynta ama ogeysiisyada) iyadoo la raacayo heshiisyada ilaalinta xogta, maamulka ururkaaga si ay u maamulaan akoonnada, ama marka sharcigu dalbado.";
"privacy_rights_title" = "Ikhtiyaarradaada iyo xuquuqahaaga";
"privacy_rights_body" = "Waxaad dib u eegi kartaa ama cusboonaysiin kartaa xogtaada profile-ka ee app-ka. Meesha ay khuseyso, waxaad codsan kartaa gelitaan, sixid, tirtirid, xaddidid, ama la-qaadashada xogtaada, ama aad ka hor imaan karto habayn gaar ah. Waxaad ka laaban kartaa xogta ikhtiyaariga ah adigoo tirtiraya nuxurkaas ama joojinaya diristiisa.";
"privacy_security_title" = "Amniga";
"privacy_security_body" = "Waxaan hirgelinaa tallaabooyin farsamo iyo kuwo urureed, sida sirgalinta inta lagu jiro gudbinta (TLS), xakamaynta aqoonsiga, gelitaan ku kooban mudnaanta ugu yar, iyo kormeer, si loo yareeyo halista gelitaanka ama shaacinta aan la oggolayn. Ilaali aqoonsiyadaada.";
"privacy_children_title" = "Xogta carruurta";
"privacy_children_body" = "App-ku wuxuu u adeegaa barayaal loo oggolaaday iyada oo loo marayo ururo la-hawlgalayaal ah. Haddii xogta cunug la ururiyey iyada oo aan oggolaansho loo baahnayn, nala soo xiriir si aan u tirtirno.";
"privacy_updates_title" = "Cusboonaysiinta siyaasadda";
"privacy_updates_body" = "Waxaan cusboonaysiin karnaa siyaasaddan si ay u muujiso isbeddelada badeecadda, amniga, ama shuruudaha sharciga. Cusboonaysiinta muhiimka ah waxaa lagu soo sheegi doonaa ogeysiisyo gudaha app-ka ama kanaalo kale oo ku habboon.";
"privacy_contact_title" = "Xiriir";
"privacy_contact_body" = "Su'aalo ama si aad u isticmaasho xuquuqdaada asturnaanta, la xiriir maamulka ururkaaga ama kooxdayada taageerada.";
