"eula_subtitle" = "Open Learning Exchange";
"eula_section1_title" = "1. Acceptance of the Agreement";
"eula_section1_body" = "By selecting \"Accept\" within this Android application, you confirm that you have read, understood, and agree to the terms set forth in this End User License Agreement (the \"Agreement\").";
"eula_section2_title" = "2. Ownership";
"eula_section2_body" = "Open Learning Exchange (\"OLE\") is the owner of the Planet, myPlanet, and myPlanetLite applications, including their content, design, code, and related materials.";
"eula_section3_title" = "3. License of Use";
"eula_section3_body" = "OLE grants the user a limited, personal, non-exclusive, non-transferable license to install and use this Android application solely for the purposes permitted by their institution or organization.";
"eula_section4_title" = "4. Data, Security, and Privacy";
"eula_section4_body" = "4.1. The Applications require collecting and processing personal data necessary for authentication, operation, and user synchronization.\n4.2. All data transmitted or stored by the Applications is encrypted in compliance with applicable security standards.\n4.3. The user agrees that use of the Applications involves such secure processing.";
"eula_section5_title" = "5. System Deactivation";
"eula_section5_body" = "If the user decides to deactivate or delete their account, they must contact an administrator within the Planet platform, who will manage access closure or data deletion according to established procedures.";
"eula_section6_title" = "6. User Obligations";
"eula_section6_body" = "The user agrees to:\n• Use the application responsibly and in accordance with applicable regulations.\n• Keep assigned login information secure.\n• Report any misuse or suspicious behavior to their institutional administrator.";
"eula_section7_title" = "7. Modifications to the Agreement";
"eula_section7_body" = "OLE may update these terms when necessary. Continued use of the application after any change constitutes acceptance of the updated Agreement.";
"eula_section8_title" = "8. Confirmation";
"eula_section8_body" = "By tapping \"Accept\", you acknowledge that:\n• You have read this Agreement.\n• You understand its scope.\n• You fully accept its terms and conditions.";
