"privacy_title" = "गोपनीयता नीति";
"privacy_intro_title" = "परिचय";
"privacy_intro_body" = "यह गोपनीयता नीति सेवा का उपयोग करने पर आपकी जानकारी के संग्रह, उपयोग और प्रकटीकरण पर हमारी नीतियों और प्रक्रियाओं का वर्णन करती है और आपको आपके गोपनीयता अधिकारों और कानून आपकी रक्षा कैसे करता है, इसके बारे में बताती है।\n\nहम सेवा प्रदान करने और सुधारने के लिए आपके व्यक्तिगत डेटा का उपयोग करते हैं। सेवा का उपयोग करके, आप इस गोपनीयता नीति के अनुसार जानकारी के संग्रह और उपयोग से सहमत होते हैं।\n\nअंतिम अद्यतन: 10 अप्रैल, 2020";
"privacy_definitions_title" = "व्याख्या और परिभाषाएं";
"privacy_definitions_body" = "जिन शब्दों का पहला अक्षर बड़ा है, उनके अर्थ निम्नलिखित परिस्थितियों में परिभाषित किए गए हैं। निम्नलिखित परिभाषाओं का एक ही अर्थ होगा चाहे वे एकवचन में हों या बहुवचन में।\n\n• कंपनी का अर्थ है ओपन लर्निंग एक्सचेंज, वन ब्रॉडवे, ब्रॉडवे, कैम्ब्रिज, एमए, संयुक्त राज्य अमेरिका।\n• एप्लिकेशन का अर्थ कंपनी द्वारा प्रदान किया गया सॉफ़्टवेयर प्रोग्राम है जिसे आपने किसी भी इलेक्ट्रॉनिक डिवाइस पर डाउनलोड किया है, जिसका नाम myPlanet है।\n• व्यक्तिगत डेटा कोई भी ऐसी जानकारी है जो किसी पहचाने गए या पहचाने जाने योग्य व्यक्ति से संबंधित है।\n• उपयोग डेटा सेवा के उपयोग से या सेवा बुनियादी ढांचे से स्वतः उत्पन्न होने वाले डेटा को संदर्भित करता है।";
"privacy_collect_title" = "आपका व्यक्तिगत डेटा एकत्र करना और उपयोग करना";
"privacy_collect_body" = "हमारी सेवा का उपयोग करते समय, हम आपसे हमें कुछ व्यक्तिगत रूप से पहचान योग्य जानकारी प्रदान करने के लिए कह सकते हैं जिसका उपयोग आपसे संपर्क करने या आपकी पहचान करने के लिए किया जा सकता है। व्यक्तिगत रूप से पहचान योग्य जानकारी में शामिल हो सकता है, लेकिन यह इन्हीं तक सीमित नहीं है: ईमेल पता, फोन नंबर, पता, राज्य, प्रांत, ज़िप/पोस्टल कोड, शहर और उपयोग डेटा।\n\nउपयोग डेटा सेवा का उपयोग करते समय स्वतः एकत्र किया जाता है। इसमें आपके डिवाइस का आईपी पता, ब्राउज़र प्रकार, ब्राउज़र संस्करण, आपके द्वारा विज़िट किए गए हमारी सेवा के पृष्ठ और अन्य नैदानिक डेटा जैसी जानकारी शामिल हो सकती है।\n\nहमारे एप्लिकेशन का उपयोग करते समय, हम आपकी पूर्व अनुमति से एकत्र कर सकते हैं: आपके स्थान के संबंध में जानकारी, आपके डिवाइस के कैमरे और फोटो लाइब्रेरी से चित्र और अन्य जानकारी।";
"privacy_use_title" = "आपके व्यक्तिगत डेटा का उपयोग";
"privacy_use_body" = "कंपनी व्यक्तिगत डेटा का उपयोग हमारी सेवा प्रदान करने और बनाए रखने, आपके खाते का प्रबंधन करने, अनुबंध के निष्पादन के लिए, आपसे संपर्क करने, आपको समाचार और विशेष ऑफ़र प्रदान करने और आपके अनुरोधों को प्रबंधित करने के लिए कर सकती है।\n\nहम आपकी व्यक्तिगत जानकारी सेवा प्रदाताओं के साथ, व्यावसायिक हस्तांतरण के लिए, सहयोगियों के साथ, व्यावसायिक भागीदारों के साथ और अन्य उपयोगकर्ताओं के साथ साझा कर सकते हैं।";
"privacy_retention_title" = "आपके व्यक्तिगत डेटा का प्रतिधारण";
"privacy_retention_body" = "कंपनी आपके व्यक्तिगत डेटा को केवल तब तक रखेगी जब तक इस गोपनीयता नीति में निर्धारित उद्देश्यों के लिए आवश्यक हो। हम अपने कानूनी दायित्वों का पालन करने, विवादों को सुलझाने और अपने कानूनी समझौतों और नीतियों को लागू करने के लिए आवश्यक सीमा तक आपके व्यक्तिगत डेटा को बनाए रखेंगे और उपयोग करेंगे।";
"privacy_transfer_title" = "आपके व्यक्तिगत डेटा का हस्तांतरण";
"privacy_transfer_body" = "व्यक्तिगत डेटा सहित आपकी जानकारी कंपनी के परिचालन कार्यालयों और किसी भी अन्य स्थान पर संसाधित की जाती है जहाँ प्रसंस्करण में शामिल पक्ष स्थित हैं। इसका अर्थ है कि यह जानकारी आपके राज्य, प्रांत, देश या अन्य सरकारी अधिकार क्षेत्र के बाहर स्थित कंप्यूटरों पर स्थानांतरित और बनाए रखी जा सकती है जहाँ डेटा सुरक्षा कानून आपके अधिकार क्षेत्र से भिन्न हो सकते हैं।";
"privacy_disclosure_title" = "आपके व्यक्तिगत डेटा का प्रकटीकरण";
"privacy_disclosure_body" = "यदि कंपनी विलय, अधिग्रहण या परिसंपत्ति बिक्री में शामिल है, तो आपका व्यक्तिगत डेटा स्थानांतरित किया जा सकता है। कुछ परिस्थितियों में, कंपनी को कानून द्वारा आवश्यक होने पर या सार्वजनिक प्राधिकरणों के वैध अनुरोधों के जवाब में आपके व्यक्तिगत डेटा का खुलासा करने की आवश्यकता हो सकती है।\n\nकंपनी सद्भावपूर्वक विश्वास के साथ आपके व्यक्तिगत डेटा का खुलासा कर सकती है कि ऐसा कार्य आवश्यक है: कानूनी दायित्व का पालन करना, कंपनी के अधिकारों या संपत्ति की रक्षा करना, संभावित गलत कामों को रोकना या उनकी जांच करना, उपयोगकर्ताओं की व्यक्तिगत सुरक्षा की रक्षा करना, या कानूनी दायित्व के खिलाफ रक्षा करना।";
"privacy_security_title" = "आपके व्यक्तिगत डेटा की सुरक्षा";
"privacy_security_body" = "आपके व्यक्तिगत डेटा की सुरक्षा हमारे लिए महत्वपूर्ण है, लेकिन याद रखें कि इंटरनेट पर प्रसारण का कोई भी तरीका, या इलेक्ट्रॉनिक भंडारण का तरीका 100% सुरक्षित नहीं है। हालांकि हम आपके व्यक्तिगत डेटा की सुरक्षा के लिए व्यावसायिक रूप से स्वीकार्य साधनों का उपयोग करने का प्रयास करते हैं, हम इसकी पूर्ण सुरक्षा की गारंटी नहीं दे सकते।";
"privacy_children_title" = "बच्चों की गोपनीयता";
"privacy_children_body" = "हमारी सेवा 13 वर्ष से कम उम्र के किसी भी व्यक्ति को संबोधित नहीं करती है। हम जानबूझकर 13 वर्ष से कम उम्र के किसी भी व्यक्ति से व्यक्तिगत रूप से पहचान योग्य जानकारी एकत्र नहीं करते हैं। यदि हमें पता चलता है कि हमने माता-पिता की सहमति के सत्यापन के बिना 13 वर्ष से कम उम्र के किसी भी व्यक्ति से व्यक्तिगत डेटा एकत्र किया है, तो हम उस जानकारी को अपने सर्वर से हटाने के लिए कदम उठाते हैं।";
"privacy_links_title" = "अन्य वेबसाइटों के लिंक";
"privacy_links_body" = "हमारी सेवा में अन्य वेबसाइटों के लिंक हो सकते हैं जो हमारे द्वारा संचालित नहीं हैं। यदि आप किसी तीसरे पक्ष के लिंक पर क्लिक करते हैं, तो आपको उस तीसरे पक्ष की साइट पर निर्देशित किया जाएगा। हम आपको दृढ़ता से सलाह देते हैं कि आप जिस भी साइट पर जाएं उसकी गोपनीयता नीति की समीक्षा करें।";
"privacy_updates_title" = "इस गोपनीयता नीति में परिवर्तन";
"privacy_updates_body" = "हम समय-समय पर अपनी गोपनीयता नीति को अपडेट कर सकते हैं। हम इस पृष्ठ पर नई गोपनीयता नीति पोस्ट करके आपको किसी भी बदलाव के बारे में सूचित करेंगे। आपको किसी भी बदलाव के लिए समय-समय पर इस गोपनीयता नीति की समीक्षा करने की सलाह दी जाती है।";
"privacy_contact_title" = "हमसे संपर्क करें";
"privacy_contact_body" = "यदि आपके पास इस गोपनीयता नीति के बारे में कोई प्रश्न हैं, तो आप हमें ईमेल द्वारा संपर्क कर सकते हैं: solutions@ole.org";
