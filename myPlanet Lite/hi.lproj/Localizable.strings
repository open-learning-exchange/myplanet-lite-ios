"privacy_intro_title" = "परिचय";
"privacy_intro_body" = "यह गोपनीयता नीति बताती है कि आपकी संस्था के माध्यम से उपलब्ध MyPlanet Lite, ऐप के उपयोग के दौरान व्यक्तिगत डेटा को कैसे संभालता है।";
"privacy_collect_title" = "हम कौन-सी जानकारी एकत्र करते हैं";
"privacy_collect_body" = "हम एकत्र करते हैं:\n• खाता डेटा (नाम, उपयोगकर्ता नाम, ईमेल, संस्था)।\n• उपयोग और निदान संबंधी जानकारी (सत्र गतिविधि, फीचर इंटरैक्शन, डिवाइस और ऐप संस्करण)।\n• वैकल्पिक सामग्री जो आप भेजते हैं (पोस्ट, सर्वे प्रतिक्रियाएँ, मीडिया फ़ाइलें)।";
"privacy_use_title" = "हम आपकी जानकारी का उपयोग कैसे करते हैं";
"privacy_use_body" = "हम डेटा का उपयोग मुख्य सुविधाएँ प्रदान करने, सीखने की सामग्री को सिंक करने, भाषा और क्षेत्रीय सेटिंग्स को अनुकूलित करने, प्रदर्शन और विश्वसनीयता में सुधार करने, और सुरक्षा, धोखाधड़ी की रोकथाम तथा जांच में समर्थन के लिए करते हैं।";
"privacy_storage_title" = "भंडारण और संरक्षण";
"privacy_storage_body" = "जानकारी OLE या आपकी संस्था द्वारा प्रबंधित सुरक्षित सर्वरों पर एक्सेस नियंत्रण और ट्रांज़िट में एन्क्रिप्शन के साथ संग्रहीत होती है। हम डेटा को केवल उतने समय तक रखते हैं जितना सेवा प्रदान करने, कानूनी आवश्यकताओं को पूरा करने, समझौतों को लागू करने या विवादों को सुलझाने के लिए आवश्यक है, बैकअप के लिए सीमित संरक्षण के साथ।";
"privacy_share_title" = "साझाकरण और तृतीय पक्ष";
"privacy_share_body" = "हम व्यक्तिगत डेटा नहीं बेचते। जानकारी विश्वसनीय सेवा प्रदाताओं (जैसे होस्टिंग, एनालिटिक्स या नोटिफिकेशन) के साथ डेटा सुरक्षा समझौतों के तहत, आपकी संस्था के प्रशासकों के साथ खाते प्रबंधन के लिए, या कानून द्वारा आवश्यक होने पर साझा की जा सकती है।";
"privacy_rights_title" = "आपके विकल्प और अधिकार";
"privacy_rights_body" = "आप ऐप में अपने प्रोफ़ाइल डेटा की समीक्षा या अपडेट कर सकते हैं। जहाँ लागू हो, आप डेटा तक पहुँच, सुधार, हटाने, प्रतिबंध या पोर्टेबिलिटी का अनुरोध कर सकते हैं, या कुछ प्रोसेसिंग का विरोध कर सकते हैं। आप वैकल्पिक डेटा को उस सामग्री को हटाकर या भेजना बंद करके वापस ले सकते हैं।";
"privacy_security_title" = "सुरक्षा";
"privacy_security_body" = "हम तकनीकी और संगठनात्मक उपाय लागू करते हैं, जैसे ट्रांज़िट में एन्क्रिप्शन (TLS), प्रमाणीकरण नियंत्रण, न्यूनतम विशेषाधिकार पहुंच और मॉनिटरिंग, ताकि अनधिकृत पहुंच या प्रकटीकरण के जोखिम को कम किया जा सके। अपनी क्रेडेंशियल्स सुरक्षित रखें।";
"privacy_children_title" = "नाबालिगों का डेटा";
"privacy_children_body" = "यह ऐप साझेदार संगठनों के माध्यम से अधिकृत शिक्षार्थियों के लिए है। यदि आवश्यक सहमति के बिना किसी नाबालिग का डेटा एकत्र हुआ है, तो उसे हटाने के लिए हमसे संपर्क करें।";
"privacy_updates_title" = "नीति अपडेट";
"privacy_updates_body" = "हम उत्पाद, सुरक्षा या कानूनी आवश्यकताओं में बदलाव को दर्शाने के लिए इस नीति को अपडेट कर सकते हैं। महत्वपूर्ण अपडेट इन-ऐप नोटिस या अन्य उपयुक्त चैनलों के माध्यम से बताए जाएंगे।";
"privacy_contact_title" = "संपर्क";
