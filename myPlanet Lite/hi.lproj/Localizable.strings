"eula_title" = "एंड यूज़र लाइसेंस एग्रीमेंट (EULA)";
"eula_subtitle" = "Open Learning Exchange";
"eula_section1_title" = "1. समझौते की स्वीकृति";
"eula_section1_body" = "इस Android ऐप में \"स्वीकारें\" चुनकर, आप पुष्टि करते हैं कि आपने इस एंड यूज़र लाइसेंस एग्रीमेंट (\"समझौता\") को पढ़ा, समझा और स्वीकार किया है।";
"eula_section2_title" = "2. स्वामित्व";
"eula_section2_body" = "Open Learning Exchange (\"OLE\") Planet, myPlanet और myPlanetLite ऐप्स की मालिक है, जिसमें उनका कंटेंट, डिज़ाइन, कोड और संबंधित सामग्री शामिल है।";
"eula_section3_title" = "3. उपयोग का लाइसेंस";
"eula_section3_body" = "OLE उपयोगकर्ता को सीमित, व्यक्तिगत, गैर-विशिष्ट और गैर-हस्तांतरणीय लाइसेंस देता है ताकि वह इस Android ऐप को केवल अपनी संस्था या संगठन द्वारा अनुमत उद्देश्यों के लिए इंस्टॉल और उपयोग कर सके।";
"eula_section4_title" = "4. डेटा, सुरक्षा और गोपनीयता";
"eula_section4_body" = "4.1. ऐप्स को प्रमाणीकरण, संचालन और उपयोगकर्ता सिंक्रोनाइज़ेशन के लिए आवश्यक व्यक्तिगत डेटा एकत्र और प्रोसेस करना होता है।\n4.2. ऐप्स द्वारा भेजा या संग्रहीत सभी डेटा लागू सुरक्षा मानकों के अनुसार एन्क्रिप्टेड होता है।\n4.3. उपयोगकर्ता स्वीकार करता है कि ऐप्स का उपयोग ऐसे सुरक्षित प्रोसेसिंग को शामिल करता है।";
"eula_section5_title" = "5. सिस्टम से हटना";
"eula_section5_body" = "यदि उपयोगकर्ता अपने खाते को निष्क्रिय या हटाना चाहता है, तो उसे Planet प्लेटफ़ॉर्म में किसी प्रशासक से सीधे संपर्क करना होगा, जो निर्धारित प्रक्रियाओं के अनुसार एक्सेस बंद या डेटा हटाने का प्रबंधन करेगा।";
"eula_section6_title" = "6. उपयोगकर्ता की जिम्मेदारियाँ";
"eula_section6_body" = "उपयोगकर्ता सहमत है कि वह:\n• ऐप का जिम्मेदारी से और लागू नियमों के अनुरूप उपयोग करेगा।\n• दिए गए लॉगिन विवरण सुरक्षित रखेगा।\n• किसी भी दुरुपयोग या संदिग्ध व्यवहार की रिपोर्ट अपने संस्थागत प्रशासक को करेगा।";
"eula_section7_title" = "7. समझौते में संशोधन";
"eula_section7_body" = "OLE आवश्यक होने पर इन शर्तों को अपडेट कर सकता है। किसी भी बदलाव के बाद ऐप का निरंतर उपयोग अपडेटेड समझौते की स्वीकृति माना जाएगा।";
"eula_section8_title" = "8. पुष्टि";
"eula_section8_body" = "\"स्वीकारें\" पर टैप करके, आप स्वीकार करते हैं कि:\n• आपने यह समझौता पढ़ा है।\n• आप इसके दायरे को समझते हैं।\n• आप इसके नियमों और शर्तों को पूरी तरह स्वीकार करते हैं।";
